# Ignore /scripts/ CONTENTS (not the dir itself) so the !exceptions below can
# re-include specific files — `/scripts/` would exclude the dir and break negation.
/scripts/*
# Exceptions: pipeline scripts that MUST be tracked — build, CI, and npm
# commands reference these, so a fresh clone / FAH build / GitHub Action needs
# them present. Everything else under /scripts/ stays local one-off tooling.
!/scripts/generate-blog-index.mjs
!/scripts/generate-client-catalog.mjs
!/scripts/reveal-blog.mjs
!/scripts/post-scheduled-articles.mjs
!/scripts/social-post-ledger.json
